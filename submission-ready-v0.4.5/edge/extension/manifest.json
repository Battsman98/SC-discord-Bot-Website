{
  "manifest_version": 3,
  "name": "Game Assist RSI Hangar Importer",
  "version": "0.4.5",
  "description": "Imports only pledged ships and vehicles from your RSI hangar using your browser session.",
  "host_permissions": [
    "https://robertsspaceindustries.com/*"
  ],
  "permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sccompanion.org/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_title": "Game Assist RSI Hangar Importer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
