{
  "manifest_version": 3,
  "name": "Game Assist RSI Hangar Importer",
  "version": "0.3.1",
  "description": "Imports only pledged ships and vehicles from your RSI hangar using your browser session.",
  "host_permissions": [
    "https://robertsspaceindustries.com/*"
  ],
  "permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://star-citizen-game-assist.onrender.com/*",
        "http://127.0.0.1:8000/*",
        "http://localhost:8000/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_title": "Game Assist RSI Hangar Importer"
  }
}
